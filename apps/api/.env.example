# HubMail API — copie para .env
PORT=3002
# Origens do *browser* permitidas no CORS (webmail), separadas por vírgula.
# O host da API (ex.: api.hubmail.to) NÃO entra aqui — entram os domínios onde o Next abre (www e apex).
# Dev local:  http://localhost:3010
# Produção:   basta https://hubmail.to — a API adiciona automaticamente o par www. ↔ apex
APP_URL=http://localhost:3010
# Origens extra (opcional), fundidas com APP_URL — útil no painel Vercel se APP_URL for uma só.
# CORS_ORIGINS=

# Sincronizar com o painel: `vercel link` e `vercel env pull` (em apps/api) — produção: `pnpm run vercel:push-env:production`.
# Integração Vercel → Supabase (nomes "STORAGE_*" do painel). Usar só estes; o Nest/Prisma leem a partir daqui.
# STORAGE_SUPABASE_URL=
# STORAGE_SUPABASE_ANON_KEY=
# STORAGE_SUPABASE_SERVICE_ROLE_KEY=
# Prisma: pooler + direct (migrations) — ver `schema.prisma`
# STORAGE_POSTGRES_PRISMA_URL=
# STORAGE_POSTGRES_URL_NON_POOLING=
# Alternativa legada (o arranque da API copia para STORAGE_* antes do Prisma):
# DATABASE_URL=
# DIRECT_URL=

# --- Mail plane (Stalwart) ---
# JMAP session URL (obrigatório para o webmail sincronizar pastas e mensagens)
STALWART_JMAP_URL=https://mail.hubmail.to/jmap/session
# Opcional: forçar o POST JMAP (apiUrl) se o anúncio do Stalwart/nginx falhar (ex.: TLS vs HTTP no mesmo path).
# STALWART_JMAP_API_URL=https://mail.hubmail.to/jmap
# SMTP submission (envio)
STALWART_SMTP_HOST=mail.hubmail.to
STALWART_SMTP_PORT=587
# Portas extra de fallback (csv). Ex.: 465 para SMTPS implícito.
# STALWART_SMTP_FALLBACK_PORTS=465
# Chave AES-256 (base64 de 32 bytes) para cifrar senhas de mailbox em repouso.
# Gere com: `openssl rand -base64 32`
MAIL_CREDENTIAL_KEY=

# --- Webhook ingest (Fase 2) ---
# Segredo HMAC por omissão quando o domínio não tem `webhook_secret` próprio.
WEBHOOK_DEFAULT_SECRET=

# --- Queue (Fase 2) ---
# URL Redis para BullMQ (Upstash / Railway / Redis Cloud). Deixe vazio em dev
# para desativar filas (o enqueue passa a ser no-op).
REDIS_URL=

# Ativa os workers BullMQ neste processo. Em Vercel Functions tem de ser `false`
# (processos são efémeros). Num host long-running (VPS/Docker) arranque com
# `WORKERS_ENABLED=true node dist/workers`.
WORKERS_ENABLED=false

# Desativa o Swagger em produção serverless para evitar 500 ao servir UI estática.
# SWAGGER_DISABLED=true
