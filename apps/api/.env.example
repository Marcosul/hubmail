# HubMail API — copie para .env e preencha
PORT=3002
APP_URL=http://localhost:3010

SUPABASE_URL=https://xxxx.supabase.co
# Chave publishable (anon) — recomendada para signInWithPassword / signInWithIdToken no servidor
SUPABASE_ANON_KEY=
# Service role — obrigatória para validar JWT (Bearer) em rotas protegidas
SUPABASE_SERVICE_ROLE_KEY=

# Pooler (runtime) — ex.: …pooler.supabase.com:6543…?pgbouncer=true
DATABASE_URL=
# Migrações Prisma: conexão direta (host `db.<project-ref>.supabase.co:5432`, user `postgres`).
# Evita erro "Tenant or user not found" com o pooler Supavisor na porta 5432.
DIRECT_URL=
