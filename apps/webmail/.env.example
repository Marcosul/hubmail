# HubMail webmail — copie para .env.local

# URL base da API Nest. O cliente chama rotas como `/api/mailboxes`, `/api/workspaces`, etc.
#
# Podes usar qualquer um destes formatos (em `src/api/rest/generic.ts` evita-se sempre `.../api/api/...`):
#   - Só o origin:     https://api.hubmail.to
#   - Com prefixo /api: https://api.hubmail.to/api   → pedido final: https://api.hubmail.to/api/mailboxes
#
# Dev local (Nest com prefixo global `api`, porta 3002):
#   http://localhost:3002/api
NEXT_PUBLIC_API_URL=https://api.hubmail.to/api

# Host da aplicação (usado em redirects OAuth)
# NEXT_PUBLIC_APP_URL=https://hubmail.to
# NEXT_PUBLIC_AUTH_REDIRECT_URL=https://hubmail.to/auth/callback

# Supabase (padrão; aceita também NEXT_PUBLIC_STORAGE_* da integração Vercel)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Alternativa (nomes Vercel / Supabase Storage)
# NEXT_PUBLIC_STORAGE_SUPABASE_URL=
# NEXT_PUBLIC_STORAGE_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_STORAGE_SUPABASE_PUBLISHABLE_KEY=

# Página /enterprise — embed Cal.com (URL completo do evento; acrescenta-se `embed=true` em cal.com se faltar)
# NEXT_PUBLIC_ENTERPRISE_CAL_EMBED_URL=https://cal.com/sua-equipa/enterprise?embed=true
# Email de contacto quando o embed não está configurado
# NEXT_PUBLIC_ENTERPRISE_CONTACT_EMAIL=enterprise@hubmail.to

# Rodapé — links sociais (opcional; omitir esconde o ícone)
# NEXT_PUBLIC_SOCIAL_GITHUB_URL=https://github.com/hubmail
# NEXT_PUBLIC_SOCIAL_DISCORD_URL=
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
# NEXT_PUBLIC_SOCIAL_X_URL=
