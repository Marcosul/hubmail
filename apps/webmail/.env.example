# HubMail webmail (Next.js) — copie para .env.local
# Chaves públicas (anon) em: https://supabase.com/dashboard/project/_/settings/api

# URL do projeto (mesma base que SUPABASE_URL na API, com https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://lkpojowpoivoyihqebqw.supabase.co

# URL pública do webmail para montar o redirect OAuth (sem espaço no fim; use http://localhost:3010 em dev)
NEXT_PUBLIC_APP_URL=http://localhost:3010

# "anon" / public — JWT (Project API keys > anon public) ou chave publishable (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev: o webmail sobe em 3010 (ver package.json). Em Authentication > URL Configuration, inclua o redirect:
#   http://localhost:3010/auth/callback
# Produção (ex.): https://hubmail.to/auth/callback
