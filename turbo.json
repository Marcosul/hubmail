{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "NODE_ENV",
    "PORT",
    "APP_URL",
    "CORS_ORIGINS",
    "STORAGE_SUPABASE_URL",
    "STORAGE_SUPABASE_ANON_KEY",
    "STORAGE_SUPABASE_SERVICE_ROLE_KEY",
    "STORAGE_SUPABASE_JWT_SECRET",
    "STORAGE_SUPABASE_SECRET_KEY",
    "STORAGE_SUPABASE_PUBLISHABLE_KEY",
    "STORAGE_POSTGRES_PRISMA_URL",
    "STORAGE_POSTGRES_URL_NON_POOLING",
    "STORAGE_POSTGRES_URL",
    "STORAGE_POSTGRES_HOST",
    "STORAGE_POSTGRES_USER",
    "STORAGE_POSTGRES_PASSWORD",
    "STORAGE_POSTGRES_DATABASE",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "STALWART_JMAP_URL",
    "STALWART_SMTP_HOST",
    "STALWART_SMTP_PORT",
    "STALWART_BASE_URL",
    "MAIL_CREDENTIAL_KEY",
    "WEBHOOK_DEFAULT_SECRET",
    "REDIS_URL",
    "WORKERS_ENABLED",
    "SWAGGER_DISABLED",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_AUTH_REDIRECT_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_STORAGE_SUPABASE_URL",
    "NEXT_PUBLIC_STORAGE_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_STORAGE_SUPABASE_PUBLISHABLE_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
