{
  "name": "hubmail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm exec turbo dev",
    "build": "pnpm exec turbo build",
    "lint": "pnpm exec turbo lint",
    "test": "pnpm exec turbo test",
    "dev:webmail": "pnpm exec turbo dev --filter=@hubmail/webmail",
    "dev:api": "pnpm exec turbo dev --filter=@hubmail/api",
    "db:deploy": "pnpm --filter @hubmail/api run db:deploy",
    "deploy:api": "pnpm exec vercel --cwd apps/api --prod",
    "deploy:webmail": "pnpm exec vercel --cwd apps/webmail --prod",
    "vercel:api": "pnpm exec vercel --cwd apps/api",
    "vercel:webmail": "pnpm exec vercel --cwd apps/webmail",
    "vercel:login": "pnpm exec vercel login",
    "vercel:push-env:production": "node scripts/vercel-push-production-env.cjs"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "vercel": "^52.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
